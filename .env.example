# ─── Vectra — Environment Variables ────────────────────────────────────────────
# Copy this file to .env and fill in real values for local development.
# For Vercel: add these as Environment Variables in the project settings.
# ────────────────────────────────────────────────────────────────────────────────

# ── Unsplash (image search in Insert drawer) ─────────────────────────────────
VITE_UNSPLASH_ACCESS_KEY=your_unsplash_access_key

# ── AI Agent ─────────────────────────────────────────────────────────────────
# Set VITE_AI_USE_CLOUD_LLM=false to run in heuristics-only (no API calls).
VITE_AI_USE_LOCAL_HEURISTICS=true
VITE_AI_USE_CLOUD_LLM=false
VITE_AI_PROVIDER=openai

# Primary HF Router key — used by Code Generator (GLM-4.7-Flash:cheapest)
VITE_AI_PRIMARY_KEY=your_huggingface_token_here

# Debugger HF Router key — used by SRE Agent (DeepSeek-V3:together)
# Use a DIFFERENT HF account token to avoid shared rate limits.
VITE_AI_DEBUGGER_KEY=your_second_huggingface_token_here

# Legacy fallback (used if VITE_AI_PRIMARY_KEY is not set)
VITE_AI_HF_TOKEN=your_huggingface_token_here

# OpenRouter backup key (optional, not actively used)
VITE_OPENROUTER_API_KEY=sk-or-v1-your_openrouter_key

# Ollama local endpoint (optional, for self-hosted models)
VITE_AI_OLLAMA_ENDPOINT=http://localhost:11434/api/generate

# OpenAI-compatible base URL (used when VITE_AI_PROVIDER=openai)
VITE_AI_OPENAI_BASE_URL=https://router.huggingface.co/v1/chat/completions
VITE_AI_OPENAI_MODEL=zai-org/GLM-4.7-Flash:cheapest
