# ── pnpm configuration ──────────────────────────────────────────────────────
# Enforce pnpm as the only package manager for this project.
# Running `npm install` or `yarn` will fail with a clear error.
engine-strict=false
shamefully-hoist=false

# Automatically approve known safe native build scripts
# (redundant with package.json#pnpm.onlyBuiltDependencies but kept for clarity)
# Only @swc/core and esbuild need postinstall scripts.
