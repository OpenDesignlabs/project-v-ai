{
  "name": "project-v",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "packageManager": "pnpm@10.27.0",
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=9.0.0",
    "npm": "please-use-pnpm",
    "yarn": "please-use-pnpm"
  },
  "scripts": {
    "dev": "vite",
    "build:engine": "curl -sSf https://rustwasm.github.io/wasm-pack/installer/init.sh | sh -s -- -y && cd vectra-engine && wasm-pack build --target web --release",
    "build:assets": "node -e \"const h=require('https'),f=require('fs');[['/babel.min.js','https://unpkg.com/@babel/standalone/babel.min.js'],['tailwind.js','https://cdn.tailwindcss.com']].forEach(([n,u])=>{const s=f.createWriteStream('public/'+n);h.get(u,r=>{if(r.statusCode>=300&&r.headers.location){h.get(r.headers.location,r2=>r2.pipe(s))}else r.pipe(s)})});\"",
    "build": "tsc -b && vite build",
    "build:full": "pnpm run build:engine && pnpm run build:assets && tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "@babel/standalone": "^7.28.6",
    "@heyputer/puter.js": "^2.2.10",
    "@insforge/sdk": "^1.1.5",
    "@number-flow/react": "^0.5.11",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@tabler/icons-react": "^3.36.1",
    "@types/babel__standalone": "^7.1.9",
    "@webcontainer/api": "^1.6.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "file-saver": "^2.0.5",
    "framer-motion": "^12.29.2",
    "jszip": "^3.10.1",
    "lucide-react": "^0.562.0",
    "openai": "^6.22.0",
    "react": "^19.2.0",
    "react-best-gradient-color-picker": "^3.0.14",
    "react-colorful": "^5.6.1",
    "react-dom": "^19.2.0",
    "tailwind-merge": "^3.4.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/file-saver": "^2.0.7",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react-swc": "^3.11.0",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.46.4",
    "vite": "^7.2.4"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@swc/core",
      "esbuild"
    ]
  }
}